# ============================================================================
# Dependencies
# ============================================================================
node_modules/
frontend/node_modules/
backend/node_modules/

# ============================================================================
# Build outputs
# ============================================================================
dist/
dist-ssr/
frontend/dist/
backend/dist/
*.tsbuildinfo

# ============================================================================
# Environment files (NEVER commit secrets!)
# ============================================================================
*.local
.env
.env.local
.env.*.local
frontend/.env
frontend/.env.local
backend/.env
backend/.env.production

# ============================================================================
# Logs
# ============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
backend/logs/
frontend/logs/

# ============================================================================
# Editor directories and files
# ============================================================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*~

# ============================================================================
# Kiro IDE specific
# ============================================================================
.kiro/

# ============================================================================
# Documentation (Internal development docs - NOT for public)
# ============================================================================
# Ignore internal development documentation
docs/**/*.md
!docs/README.md
!docs/API.md
!docs/CONTRIBUTING.md

# Ignore specific internal doc folders
docs/archive/
docs/reports/
docs/architecture/
docs/backend/
docs/frontend/
docs/code-quality-audit/
docs/guides/
docs/refactoring/

# Keep only essential public-facing documentation
# All internal planning, reports, and development docs are excluded

# ============================================================================
# Scripts (Internal development tools)
# ============================================================================
scripts/
backend/scripts/
!backend/scripts/README.md

# ============================================================================
# Test files and coverage
# ============================================================================
*.test.ts
*.test.tsx
*.test.js
*.spec.ts
*.spec.tsx
*.spec.js
**/__tests__/
test-results/
playwright-report/
coverage/
.nyc_output/
frontend/test-results/
frontend/playwright-report/
frontend/coverage/
backend/test-results/
backend/coverage/

# Test utilities and fixtures
backend/test-*.js
backend/test-*.ts
**/fixtures/
**/mocks/

