# Root monorepo ignore for Loopy

# Dependencies
**/node_modules/

# Build outputs
**/dist/
**/build/
**/.turbo/
**/.next/
**/coverage/

# Environment / secrets
**/.env
**/.env.*
!**/.env.example

# Logs
**/logs/
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.vs/
.vscode/
.idea/

# Nested repositories: keep source files, do not embed git metadata
**/.git/

# Temporary scratch/cache
**/.cache/
**/tmp/
**/temp/
