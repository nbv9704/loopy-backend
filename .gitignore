backend/public/uploads/
frontend/public/uploads/
uploads/

# ============================================================================
# Legacy files (Should not exist in root anymore)
# ============================================================================
# Frontend static assets (now in frontend/public/)
manifest.json
robots.txt
sitemap.xml

# Frontend config files (now in frontend/)
vite.config.ts
vitest.config.ts
tailwind.config.js
postcss.config.js
tsconfig.json
tsconfig.node.json
index.html

# Old source files (now in frontend/src/)
src/

# ============================================================================
# Sensitive files (NEVER commit!)
# ============================================================================
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
secrets/
.secrets/

