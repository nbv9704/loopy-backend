{
  "name": "loopy-backend",
  "version": "1.0.0",
  "description": "Loopy Backend API - Multi-language coding playground",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "quality:check": "npm run format:check && npm run lint",
    "migrate": "node dist/scripts/migrate.js",
    "seed": "node dist/scripts/seed.js",
    "migrate:content": "tsx src/scripts/migrate-content.ts",
    "rollback:content": "tsx src/scripts/rollback-content.ts",
    "verify:migration": "tsx src/scripts/verify-migration.ts",
    "verify:multilingual": "tsx src/scripts/verify-multilingual-migration.ts",
    "docs:generate": "tsx scripts/validate-openapi.ts",
    "types:generate": "tsx scripts/generate-types.ts",
    "client:generate": "tsx scripts/generate-client.ts",
    "docs:build": "npm run docs:generate && npm run types:generate",
    "seed:footer": "tsx scripts/seed-footer.ts"
  },
  "keywords": [
    "coding",
    "playground",
    "education",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.39.0",
    "ajv": "^8.18.0",
    "bullmq": "^5.76.6",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.19.0",
    "groq-sdk": "^1.1.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "isolated-vm": "^6.1.2",
    "js-yaml": "^4.1.1",
    "multer": "^2.1.1",
    "node-cache": "^5.1.2",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.6",
    "@types/node-cache": "^4.1.3",
    "@types/redis": "^4.0.10",
    "@types/socket.io": "^3.0.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "fast-check": "^4.7.0",
    "jest": "^30.3.0",
    "openapi-generator-cli": "^1.0.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
