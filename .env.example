# Server Configuration
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# CORS Configuration
# Note: Admin interface is now integrated into the main frontend
# Only the main frontend URL is needed (admin accessible at /admin)
FRONTEND_URL=http://localhost:5173

# Code Execution Configuration
CODE_EXECUTION_TIMEOUT=5000
MAX_CODE_LENGTH=10000

# Piston Code Runner Configuration
# Required for Python/C++/Java/Go/Rust live execution and stdout test cases.
# Leave empty to use Glot fallback while Piston self-host is unavailable.
# Local/VPS host-port example: http://localhost:2000/api/v2/execute
# Docker network example: http://piston:2000/api/v2/execute
PISTON_API_URL=
PISTON_API_KEY=

# Glot.io fallback runner
# Temporary fallback when Piston self-host is unavailable.
# Token: https://glot.io/account/token
GLOT_API_URL=https://glot.io/api/run
GLOT_API_TOKEN=

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_CODE_EXECUTION=50

# Logging
LOG_LEVEL=info

# Content Management System
# CACHE_TTL: Cache time-to-live in seconds for content API responses (300 = 5 minutes)
CACHE_TTL=300
# MAX_CONTENT_ITEMS_PER_PAGE: Maximum number of content items returned per page in paginated endpoints
MAX_CONTENT_ITEMS_PER_PAGE=50

# Swagger API Documentation
# SWAGGER_ENABLED: Enable/disable Swagger UI and OpenAPI spec generation (true/false)
SWAGGER_ENABLED=true
# SWAGGER_REQUIRE_AUTH: Require admin authentication to access Swagger UI (true for production, false for dev)
SWAGGER_REQUIRE_AUTH=false
# SWAGGER_INCLUDE_DEBUG: Include internal/debug endpoints in documentation (false for production, true for dev)
SWAGGER_INCLUDE_DEBUG=true

# Admin Dashboard Configuration
# ADMIN_SESSION_SECRET: Secret key for encrypting admin session cookies (CHANGE IN PRODUCTION!)
ADMIN_SESSION_SECRET=loopy-admin-secret-change-in-production
# ADMIN_SESSION_MAX_AGE: Session duration in milliseconds (28800000 = 8 hours)
ADMIN_SESSION_MAX_AGE=28800000
# ADMIN_CSRF_ENABLED: Enable CSRF protection for admin forms (true/false)
ADMIN_CSRF_ENABLED=true
# ADMIN_ITEMS_PER_PAGE: Default number of items per page in admin tables
ADMIN_ITEMS_PER_PAGE=25

# Auto-Grading System Configuration
# REDIS_URL: Redis connection URL for caching AI analysis results (optional, falls back to in-memory cache)
# Example: redis://localhost:6379 or redis://username:password@host:port
REDIS_URL=

# AI Grading Configuration
# GEMINI_API_KEY: Google Gemini API key for AI-based code analysis (fallback provider)
GEMINI_API_KEY=your_gemini_api_key_here

# GROQ_API_KEY: Groq API key for AI-based code analysis (primary provider)
GROQ_API_KEY=your_groq_api_key_here

# AI_PRIMARY_PROVIDER: Primary AI provider to use (groq or gemini)
AI_PRIMARY_PROVIDER=groq

# AI_FALLBACK_ENABLED: Enable automatic fallback to other AI providers when quota exceeded
AI_FALLBACK_ENABLED=true
